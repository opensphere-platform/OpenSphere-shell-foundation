{
  "name": "foundation",
  "version": "0.2.0-edge.8",
  "description": "OpenSphere subShell — Foundation. Angular 22 + Clarity 18, exported as Angular Element <osp-foundation-shell>. Standalone project: `ng build` → dist served by server.js (generic K8s proxy + WS exec).",
  "private": true,
  "scripts": {
    "build": "ng build --configuration production",
    "start": "ng serve",
    "serve:backend": "node server.js",
    "package:module": "node tools/package-module.mjs",
    "verify:manual": "node tools/verify-manual-contribution.mjs",
    "verify:surface": "node tools/verify-plugin-surface.mjs",
    "verify:plugin-catalog": "node tools/verify-foundation-plugin-catalog.mjs",
    "package:plugin": "node tools/package-foundation-plugin.mjs"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/elements": "^22.0.1",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@carbon/icons": "^11.82.0",
    "@cds/core": "^6.17.0",
    "@clr/angular": "^18.2.0",
    "@clr/ui": "^18.2.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chart.js": "^4.5.1",
    "js-yaml": "^4.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "ws": "^8.18.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "~6.0.0"
  }
}
