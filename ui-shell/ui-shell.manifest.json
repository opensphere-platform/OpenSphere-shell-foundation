{
  "manifestVersion": 3,
  "kind": "subShell",
  "id": "foundation",
  "hostRef": "main",
  "hostApiVersion": "1.0.0",
  "hostCompat": ">=1.0.0 <2.0.0",
  "version": "0.2.0-edge.11",
  "title": "Platform Foundation Service Stack",
  "description": "OpenSphere PFS lifecycle and foundation service module host.",
  "entry": "ui-shell.plugin.js",
  "entrySha256": "461cc4838485b8d55024f5f3310fa7447ef2992a9f6e71d52dba1b9dbc5bf10f",
  "shellCompat": ">=0.2.0 <0.9.0",
  "sdkVersion": "0.2.0",
  "permissions": [
    "page:register",
    "api:proxy",
    "manual:contribute"
  ],
  "nav": {
    "band": "운영 Operate",
    "label": "Foundation"
  },
  "designSystem": "clarity",
  "apiBase": "/api/plugins/foundation",
  "renderMode": "esm",
  "contributions": {
    "page": {
      "enabled": true
    },
    "navigation": {
      "enabled": false,
      "mode": "none",
      "reason": "Foundation owns navigation inside its page"
    },
    "api": {
      "enabled": true,
      "basePath": "/api/plugins/foundation"
    },
    "cli": {
      "enabled": false,
      "reason": "Foundation CLI manifest is not published"
    },
    "manual": {
      "enabled": true,
      "sourceId": "plugin:foundation",
      "mode": "runtime"
    },
    "search": {
      "enabled": false,
      "mode": "none",
      "reason": "Foundation search is page-local"
    },
    "notification": {
      "enabled": true,
      "frontend": false,
      "backend": true
    },
    "observability": {
      "enabled": true,
      "logs": true,
      "metrics": false,
      "traces": false,
      "reason": "Metrics and traces are pending; structured logs are available"
    }
  }
}
